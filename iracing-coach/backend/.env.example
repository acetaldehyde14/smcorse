# Server Configuration
NODE_ENV=production
PORT=3000
HOST=localhost

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iracing_coach
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_this_to_random_string
JWT_EXPIRES_IN=7d

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Llama 3.3 Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.3:70b

# CORS Configuration
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:80

# Logging
LOG_LEVEL=info
